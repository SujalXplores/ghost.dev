# ghost.dev API keys — pick at least one.
# Or just run `ghost setup` and it will prompt you interactively.
#
# Keys are saved to ~/.ghost-dev/.env so they persist across projects.

ANTHROPIC_API_KEY=your-api-key-here
# OPENROUTER_API_KEY=your-openrouter-key-here
# OPENAI_API_KEY=your-openai-key-here
